# =============================================================================
# PolyMarketBot Configuration - Copy to .env and fill in values
# =============================================================================

# --- Layer 1: Polymarket & Blockchain ---
POLYMARKET_HOST=https://clob.polymarket.com
POLYGON_CHAIN_ID=137
# Your wallet private key (WITH 0x prefix). NEVER commit this.
PRIVATE_KEY=0x_your_private_key_here
# Signature type: 0=EOA, 1=Magic/Email, 2=Browser proxy
SIGNATURE_TYPE=0
FUNDER_ADDRESS=

# Polymarket API credentials (derived on first run)
CLOB_API_KEY=
CLOB_API_SECRET=
CLOB_API_PASSPHRASE=

# Alchemy RPC URL for Polygon
ALCHEMY_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# --- Layer 2: AI (Anthropic Claude) ---
ANTHROPIC_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-sonnet-4-20250514

# --- Layer 5: Telegram Monitoring ---
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_CHAT_ID=123456789

# --- Trading Parameters ---
SCAN_INTERVAL_SECONDS=300
MIN_EDGE=0.05
MAX_SLIPPAGE=0.02
KELLY_FRACTION=0.25
MAX_POSITION_USD=50.0
MAX_TOTAL_EXPOSURE_USD=500.0
MIN_MARKET_LIQUIDITY_USD=1000.0
MIN_HOURS_TO_RESOLUTION=24

# --- Database ---
DB_PATH=data/bot.db

# --- Prompt ---
ACTIVE_PROMPT_VERSION=v1
